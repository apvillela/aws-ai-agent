# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=sentinel-profiles

# ── Google / Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── GCP / BigQuery ────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=sentinel
BIGQUERY_TABLE=leads

# ── Store the GCP service account JSON key in SSM (SecureString) ──────────────
# aws ssm put-parameter \
#   --name /sentinel/gcp_service_account_key \
#   --value "$(cat gcp-key.json)" \
#   --type SecureString
GCP_SERVICE_ACCOUNT_KEY_PARAM=/sentinel/gcp_service_account_key

# ── SSM parameters to create before deploying ─────────────────────────────────
# aws ssm put-parameter --name /sentinel/pinecone_api_key --value $PINECONE_API_KEY --type SecureString
# aws ssm put-parameter --name /sentinel/gemini_api_key   --value $GEMINI_API_KEY   --type SecureString
# aws ssm put-parameter --name /sentinel/gcp_project_id   --value $GCP_PROJECT_ID   --type String
